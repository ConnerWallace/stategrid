@page "/"
@page "/game/{gameNumber:int}"
@using BlazorApp1.Components.DB
@using Microsoft.Data.Sqlite
@using BlazorApp1.Components.UserData
@rendermode InteractiveServer
@using Microsoft.AspNetCore.Components.Server.ProtectedBrowserStorage
@inject ProtectedLocalStorage storage
@inject NavigationManager Navigation

@if (Categories[0] == null)
{
    <p><em>Loading...</em></p>
}
else
{
<CascadingValue Value=@this IsFixed=true>
    <AnswerPopup @ref="popupRef" states="allStates" Validate="@(args => ValidateAnswer(args))" PreviouslyWrong="@(args => PreviouslyWrong(args))" Submit="@(args => OnSubmit(args))" />
</CascadingValue>
<Descriptions @ref="descRef"> 
</Descriptions>
<HowToPlayModal @ref="howToPlayRef"/>

<div class="top-container">
    <div>
        <img class="title" src="StateGriddleLogo.svg"/>
    </div>
    <div class="three-column-layout">
        <div class="sidebar"></div>
        <div class="board">
            <div class="panel">
                <div class="row">
                    <div class="invisible"></div>
                    <div class="prompt column-prompt" @onclick="() => ShowDes(0)">
                        <CategoryContainer CategoryTitle="@Categories[0].Name" />
                    </div>
                    <div class="prompt column-prompt" @onclick="() => ShowDes(1)">
                        <CategoryContainer CategoryTitle="@Categories[1].Name" />
                    </div>
                    <div class="prompt column-prompt" @onclick="() => ShowDes(2)">
                        <CategoryContainer CategoryTitle="@Categories[2].Name" />
                    </div>
                </div>

                <div class="row">
                    <div class="prompt row-prompt" @onclick="() => ShowDes(3)">
                        <CategoryContainer CategoryTitle="@Categories[3].Name" />
                    </div>
                    <div class="box" @onclick="() => SetValue(0)"> <AnswerContainer stateParam="@Answers[0]" rarity="@rarities[0]" /></div>
                    <div class="box" @onclick="() => SetValue(1)"> <AnswerContainer stateParam="@Answers[1]" rarity="@rarities[1]" /></div>
                    <div class="box" @onclick="() => SetValue(2)"> <AnswerContainer stateParam="@Answers[2]" rarity="@rarities[2]" /></div>

                </div>
                <div class="row">
                    <div class="prompt row-prompt" @onclick="() => ShowDes(4)">
                        <CategoryContainer CategoryTitle="@Categories[4].Name" />
                        </div>
                    <div class="box" @onclick="() => SetValue(3)"> <AnswerContainer stateParam="@Answers[3]" rarity="@rarities[3]" /></div>
                    <div class="box" @onclick="() => SetValue(4)"> <AnswerContainer stateParam="@Answers[4]" rarity="@rarities[4]" /></div>
                    <div class="box" @onclick="() => SetValue(5)"> <AnswerContainer stateParam="@Answers[5]" rarity="@rarities[5]" /></div>
                </div>
                    <div class="row">
                    <div class="prompt row-prompt" @onclick="() => ShowDes(5)">
                        <CategoryContainer CategoryTitle="@Categories[5].Name" />
                    </div>
                    <div class="box" @onclick="() => SetValue(6)"> <AnswerContainer stateParam="@Answers[6]" rarity="@rarities[6]" /></div>
                    <div class="box" @onclick="() => SetValue(7)"> <AnswerContainer stateParam="@Answers[7]" rarity="@rarities[7]" /></div>
                    <div class="box" @onclick="() => SetValue(8)"> <AnswerContainer stateParam="@Answers[8]" rarity="@rarities[8]" /></div>
                </div>
            </div>

            <div class="column">
                <div class="card column-item">
                    Game Number: @gameNumber
                </div>
                <div class="card column-item">
                    Score: @String.Format("{0:0.00}", score)
                </div>
                <div class="card column-item">
                    Guesses Remaining: @if (InfiniteGuesses){<i>&infin;</i>} else{ @GuessesLeft }
                </div>
                <div class="howtoplay card column-item" @onclick="() => howToPlayRef.show()">
                        How to Play
                </div>
                <!--
                <div class="card column-item">
                    <button >Give Up</button>
                </div>
                -->
                <div class="card column-item"> <ClipboardButton Text="@forClipboard"></ClipboardButton> </div>
                <div class="card column-item">
                    Archive
                    <button Color="ButtonColor.Primary" disabled="@isDisabled2" @onclick='() => Navigation.NavigateTo("/game/" + (gameNumber - 1))'>&lt;</button>
                    <button Color="ButtonColor.Primary" disabled="@isDisabled" @onclick='() => Navigation.NavigateTo(" /game/" + (gameNumber + 1))'>&gt;</button>
                </div>
                <div class="card">
                    <div class="form-check form-switch">
                    <input class="form-check-input" disabled="@UsedInfinite" @onclick="() => InfiniteGuesses = !InfiniteGuesses" type="checkbox" role="switch" id="flexSwitchCheckChecked" checked="@InfiniteGuesses">
                        <label class="form-check-label" for="flexSwitchCheckChecked">Infinite Guess Mode</label>
                    </div>
                </div>
            </div>
        </div>
        <div class="sidebar"></div>
    </div>
</div>
}

@code {
    private AnswerPopup popupRef;
    private Descriptions descRef;
    private HowToPlayModal howToPlayRef;
    private Category[] Categories = new Category[6];
    private double[] rarities = new double[] { 100, 100, 100, 100, 100, 100, 100, 100, 100};
    private new List<List<string>> categoriesCorrectAnswers = new List<List<string>>();

    [Parameter]
    public int? gameNumber { get; set; } 

    private List<string> allStates = new List<string>();
    private bool win = false;
    private StateinfoContext dB = new StateinfoContext();
    private UserDataContext userDataContext = new UserDataContext();
    private TestDbContext dbButBad = new TestDbContext();
    private double score = 900;
    private string forClipboard = "";
    private bool isDisabled = false;
    private bool isDisabled2 = false;
    private StoredData data = new StoredData();

    private string[] Answers {
        get
        {
            return data.Answers;
        }
    }

    private bool InfiniteGuesses
    {
        get
        {
            return data.InfiniteGuesses;
        }
        set
        {
            data.InfiniteGuesses = value;
        }
    }

    private int GuessesLeft
    {
        get
        {
            return data.GuessesLeft;
        }
    }

    private bool UsedInfinite
    {
        get
        {
            return data.UsedInfinite;
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await LoadGameState();
            StateHasChanged();
        }
    }

    private async Task LoadGameState()
    {
        var todaysGameNumber = (int)(DateTime.Now - DateTime.Parse("11/13/2025")).TotalDays; //Start Date is 11/13/2025
        if (gameNumber == null)
        {
            gameNumber = todaysGameNumber; //Loses a day for some reason
        } else
        {
            if (gameNumber > todaysGameNumber)
            {
                Navigation.NavigateTo("/not-found");
                return;
            }

        }
        if (gameNumber == todaysGameNumber)
        {
            isDisabled = true;
        }
        if (gameNumber == 1)
        {
            isDisabled2 = true;
        }

        var result = await storage.GetAsync<StoredData>("board" + gameNumber);
        data = result.Success ? result.Value : new StoredData();

        Game todaysGame = dB.Games.Single(b => b.Id == gameNumber);
        Categories[0] = dB.Categories.Single(c => c.Id == todaysGame.Cat1);
        Categories[1] = dB.Categories.Single(c => c.Id == todaysGame.Cat2);
        Categories[2] = dB.Categories.Single(c => c.Id == todaysGame.Cat3);
        Categories[3] = dB.Categories.Single(c => c.Id == todaysGame.Cat4);
        Categories[4] = dB.Categories.Single(c => c.Id == todaysGame.Cat5);
        Categories[5] = dB.Categories.Single(c => c.Id == todaysGame.Cat6);

        categoriesCorrectAnswers.Add(new List<string>());
        categoriesCorrectAnswers[0].AddRange(dbButBad.query(Categories[0].Clause));

        categoriesCorrectAnswers.Add(new List<string>());
        categoriesCorrectAnswers[1].AddRange(dbButBad.query(Categories[1].Clause));

        categoriesCorrectAnswers.Add(new List<string>());
        categoriesCorrectAnswers[2].AddRange(dbButBad.query(Categories[2].Clause));

        categoriesCorrectAnswers.Add(new List<string>());
        categoriesCorrectAnswers[3].AddRange(dbButBad.query(Categories[3].Clause));

        categoriesCorrectAnswers.Add(new List<string>());
        categoriesCorrectAnswers[4].AddRange(dbButBad.query(Categories[4].Clause));

        categoriesCorrectAnswers.Add(new List<string>());
        categoriesCorrectAnswers[5].AddRange(dbButBad.query(Categories[5].Clause));

        allStates.AddRange(dbButBad.query("Select name from States"));


        for(int i=0; i<9; i++)
        {
            if (Answers![i] == null || Answers[i] == "")
            {
                continue;
            }
            var listOfSubmittedAnswers = userDataContext.Answers.Where(c => c.Game == gameNumber && c.AnswerSlot == i).ToList();
            var currentAnswer = listOfSubmittedAnswers.Find(a => a.StateName.Equals(Answers[i], StringComparison.InvariantCultureIgnoreCase));
            int sum = 0;
            foreach (Answer answer1 in listOfSubmittedAnswers)
            {
                sum += answer1.NumberOfGuesses.GetValueOrDefault(0);
            }
            rarities[i] = (currentAnswer?.NumberOfGuesses.GetValueOrDefault(0) ?? (double)sum) / (double)sum * 100.0;
        }
        score = rarities.Sum();
        Emojify();
    }

    private async Task SetValue(int index)
    {
        var (x, y) = XYFromIndex(index);
        popupRef.Show(index, Categories[x].Name, Categories[y].Name);

    }

    private bool PreviouslyWrong((int index, string input) a)
    {
        return data.AllWrongGuesses[a.index].Find(t => string.Equals(a.input, t, StringComparison.InvariantCultureIgnoreCase)) != null;
    }

    private bool ValidateAnswer((int index, string input) a)
    {
        var (x, y) = XYFromIndex(a.index);
        var answer = a.input;
        return categoriesCorrectAnswers[x].Contains(answer, StringComparer.OrdinalIgnoreCase)
        && categoriesCorrectAnswers[y].Contains(answer, StringComparer.OrdinalIgnoreCase);
    }

    private void OnSubmit((int index, string input) a)
    {
        if (InfiniteGuesses)
        {
            data.GuessesLeft = 999;
            data.UsedInfinite = true;
        }

        if (GuessesLeft == 0) return;

        var (x, y) = XYFromIndex(a.index);
        var answer = a.input;

        if (!allStates.Contains(answer, StringComparer.OrdinalIgnoreCase))
        {
            //TODO add a visual for this
            return;
        }

        var OldAnswerLocation = Array.FindIndex<string>(Answers, 0, 9, x => string.Equals(x, answer, StringComparison.OrdinalIgnoreCase));

        if (categoriesCorrectAnswers[x].Contains(answer, StringComparer.OrdinalIgnoreCase)
        && categoriesCorrectAnswers[y].Contains(answer, StringComparer.OrdinalIgnoreCase)     
        )
        {
            if(OldAnswerLocation != -1)
            {
                Answers[OldAnswerLocation] = null;
                rarities[OldAnswerLocation] = 100;
                data.GuessesLeft++;
            }

            var hasBeenSubmitted = HadBeenSubmitted(a.index, answer);

            var listOfSubmittedAnswers = userDataContext.Answers.Where(c => c.Game == gameNumber && c.AnswerSlot == a.index).ToList();

            var currentAnswer = listOfSubmittedAnswers.Find(a => a.StateName.Equals(answer, StringComparison.InvariantCultureIgnoreCase));
            int sum = 0;
            foreach (Answer answer1 in listOfSubmittedAnswers)
            {
                sum += answer1.NumberOfGuesses.GetValueOrDefault(0);
            }
            if (currentAnswer != null)
            {
                rarities[a.index] = currentAnswer.NumberOfGuesses.GetValueOrDefault(0) / (double)sum * 100.0;
                if(!hasBeenSubmitted) currentAnswer.NumberOfGuesses += 1;
            } else
            {
                currentAnswer = new Answer
                    {
                        Game = gameNumber,
                        StateName = answer,
                        AnswerSlot = a.index,
                        NumberOfGuesses = 1
                    };
                rarities[a.index] = 0;
                userDataContext.Answers.Add(currentAnswer);
            }
            _ = userDataContext.SaveChangesAsync();


            score = rarities.Sum();
            Answers[a.index] = categoriesCorrectAnswers[x].FirstOrDefault(t => string.Equals(answer,t, StringComparison.InvariantCultureIgnoreCase))!;
        }
        else
        {
            var inList = data.AllWrongGuesses[a.index].Find(t => string.Equals(answer, t, StringComparison.InvariantCultureIgnoreCase)) != null;
            if (!inList)
            {
                data.AllWrongGuesses[a.index].Add(answer);
            }
        }

        data.GuessesLeft--;
        storage.SetAsync("board" + gameNumber, data);
        Emojify();
    }

    public void ShowDes(int index)
    {
        descRef.show(Categories[index].Description ?? 0);
        popupRef.Close();
    }

    private bool HadBeenSubmitted(int index, string answer)
    {
        var inList = data.AllGivenAnswers[index].Find(t => string.Equals(answer, t, StringComparison.InvariantCultureIgnoreCase)) != null;
        if (!inList)
        {
            data.AllGivenAnswers[index].Add(answer);
        }
        return inList;
    }

    public void Emojify()
    {
        var text = ScoreToEmoji(0) + ScoreToEmoji(1) + ScoreToEmoji(2) + "\\r\\n" +
                ScoreToEmoji(3) + ScoreToEmoji(4) + ScoreToEmoji(5) + "\\r\\n" +
                ScoreToEmoji(6) + ScoreToEmoji(7) + ScoreToEmoji(8) + "\\r\\n" +
                "score: " + @String.Format("{0:0.00}", score) +" | game #" + gameNumber + " | "+ DateTime.Today.ToShortDateString();
        if (InfiniteGuesses)
        {
            text += " | ♾️";
        }
        text += "\\r\\n https://stategriddle.com";

        forClipboard = text;
    }
    private string ScoreToEmoji(int index)
    {
        if (Answers[index] == null)
            return "❌";
        var score = rarities[index];

        switch (score)
        {
            case 0:
                return "🦅";
            case < 5:
                return "🟥";
            case < 10:
                return "🟪";
            case < 20:
                return "🟦";
            case < 30:
                return "🟨";
            default:
                return "🟩";
        }
    }

    private (int, int) XYFromIndex(int index)
    {
        switch (index)
        {
            case 0: return (0, 3);
            case 1: return (1, 3);
            case 2: return (2, 3);

            case 3: return (0, 4);
            case 4: return (1, 4);
            case 5: return (2, 4);

            case 6: return (0, 5);
            case 7: return (1, 5);
            case 8: return (2, 5);
            default: return (0, 0);
        }
    }
}
